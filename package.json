{
  "name": "tiki-place",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "automation:new-bar": "tsx -r dotenv-flow/config scripts/process-new-bar.ts",
    "automation:update-bar": "tsx -r dotenv-flow/config scripts/process-update-bar.ts",
    "automation:report-bad": "tsx -r dotenv-flow/config scripts/process-report-bad.ts",
    "automation:refresh-records": "tsx -r dotenv-flow/config scripts/refresh-records.ts"
  },
  "dependencies": {
    "@octokit/rest": "latest",
    "@photostructure/tz-lookup": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-slider": "latest",
    "@upstash/ratelimit": "latest",
    "@upstash/redis": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "latest",
    "dotenv-flow": "latest",
    "js-yaml": "latest",
    "lucide-react": "latest",
    "mapbox-gl": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "tailwindcss-animate": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/js-yaml": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "^9.18.0",
    "eslint-config-next": "latest",
    "jsdom": "latest",
    "postcss": "latest",
    "tailwindcss": "^3.4.17",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
